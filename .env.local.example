# Resend — powers the "Send to me" email option (app/api/share)
# 1. Create a key at https://resend.com/api-keys
# 2. Verify the sending domain (e.g. jungle.baby) at https://resend.com/domains
# Copy this file to .env.local and fill in the values.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From address — MUST be on a domain you've verified in Resend.
SHARE_FROM_EMAIL="Jungle Summer <summer@jungle.baby>"
